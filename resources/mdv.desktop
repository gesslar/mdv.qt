[Desktop Entry]
Type=Application
Name=mdv
GenericName=Markdown Viewer
Comment=An offline Markdown viewer.
Exec=mdv %F
Icon=mdv
Terminal=false
Categories=Office;
MimeType=text/markdown;
# Must equal the running window's Wayland app_id / X11 WM_CLASS (set via
# QGuiApplication::setDesktopFileName("mdv") in src/main.cpp) so the compositor
# matches the window to this launcher and shows Icon= in the dock/taskbar.
StartupWMClass=mdv
StartupNotify=true
